# Dynamic Platform — only two things needed
DYNAMIC_ENVIRONMENT_ID=your-environment-id
DYNAMIC_AUTH_TOKEN=dyn_your-api-token

# Optional: pre-existing EVM wallet (skip to auto-create on first use)
# WALLET_ADDRESS=0x...
# WALLET_ID=your-wallet-id

# Optional: pre-existing SOL wallet
# SOL_WALLET_ADDRESS=...
# SOL_WALLET_ID=your-sol-wallet-id

# Optional: minimum USD before triggering a cross-chain swap (default $1.00)
# MIN_FUNDING_THRESHOLD_USD=1.00

# ERC-7710 payments (erc7710 assetTransferMethod) — required only for setup-delegation.
# A funded EOA that submits the one-time EIP-7702 type-4 transaction and pays gas.
# The agent's Dynamic MPC wallet signs the authorization; the relayer sends the tx.
# RELAYER_PRIVATE_KEY=0x...

# scripts/mock-merchant.ts — optional real facilitator for on-chain settlement after pay
# X402_FACILITATOR_URL=http://localhost:8787
# Optional path if your facilitator does not use POST /settle (default /settle)
# X402_FACILITATOR_SETTLE_PATH=/settle
