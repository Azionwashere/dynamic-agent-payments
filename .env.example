# Dynamic Platform
DYNAMIC_ENVIRONMENT_ID=your-environment-id
DYNAMIC_AUTH_TOKEN=dyn_your-api-token

# Optional: pre-existing wallet (skip if you want auto-creation)
# WALLET_ADDRESS=0x...
# WALLET_ID=your-wallet-id

# x402 Facilitator
X402_FACILITATOR_URL=http://localhost:8080

# RPC for broadcasting signed transactions
RPC_URL_BASE=https://sepolia.base.org

# Optional: minimum USD amount before triggering a cross-chain swap
MIN_FUNDING_THRESHOLD_USD=1.00
