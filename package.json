{
  "name": "dynamic-agent-payments",
  "version": "0.1.0",
  "description": "CLI + library for AI agents to handle x402 paywalls via Dynamic's Checkout API and delegated MPC wallets",
  "type": "module",
  "main": "dist/lib/index.js",
  "bin": {
    "dynamic-agent-payments": "dist/cli.js",
    "dynamic-agent-payments-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "cli": "node dist/cli.js",
    "mcp": "node dist/mcp/server.js",
    "dashboard": "node dist/dashboard/server.js",
    "demo:integrity": "npx tsx demo/integrity-server.ts"
  },
  "dependencies": {
    "@dynamic-labs-wallet/node": "^0.0.323",
    "@dynamic-labs-wallet/node-evm": "^0.0.323",
    "@dynamic-labs-wallet/node-svm": "^0.0.323",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.0",
    "viem": "^2.30.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "rollup": "4.59.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "hono": "4.12.8",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
