{
  "name": "dynamic-agent-payments",
  "version": "0.1.0",
  "description": "MCP server + library for AI agents to handle x402 paywalls via Dynamic's Checkout API and delegated MPC wallets",
  "type": "module",
  "main": "dist/lib/index.js",
  "bin": {
    "dynamic-agent-payments": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "mcp": "node dist/mcp/server.js",
    "dashboard": "node dist/dashboard/server.js"
  },
  "dependencies": {
    "@dynamic-labs-wallet/node": "latest",
    "@dynamic-labs-wallet/node-evm": "latest",
    "@dynamic-labs-wallet/node-svm": "latest",
    "@modelcontextprotocol/sdk": "1.27.0",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "viem": "^2.30.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "rollup": "4.34.8",
    "@modelcontextprotocol/sdk": "1.27.0",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
